#!/usr/bin/env bash
set -euo pipefail

# Scan staged text files for common secret patterns.
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

pattern='hooks\.slack\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]+|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|AIza[0-9A-Za-z_-]{35}|sk_live_[A-Za-z0-9]{16,}|rk_live_[A-Za-z0-9]{16,}|Authorization:[[:space:]]*Bearer[[:space:]]+[A-Za-z0-9._-]{20,}|KIWOOM_APP_KEY[[:space:]]*=[[:space:]]*[A-Za-z0-9._-]{12,}|KIWOOM_SECRET_KEY[[:space:]]*=[[:space:]]*[A-Za-z0-9._-]{12,}|"appkey"[[:space:]]*:[[:space:]]*"[A-Za-z0-9._-]{12,}"|"secretkey"[[:space:]]*:[[:space:]]*"[A-Za-z0-9._-]{12,}"|BEGIN (RSA|EC|OPENSSH|PRIVATE) KEY|-----BEGIN PRIVATE KEY-----'

hits=()
while IFS= read -r f; do
  [[ -f "$f" ]] || continue

  # Skip common binary assets and dependency/vendor trees.
  case "$f" in
    .githooks/pre-commit) continue ;;
    .github/workflows/secret-scan.yml) continue ;;
    *.png|*.jpg|*.jpeg|*.gif|*.webp|*.pdf|*.zip|*.tar|*.gz|*.7z|*.bin|*.pyc) continue ;;
    .venv/*|mobile_app/node_modules/*|data/backtest_cache/*) continue ;;
  esac

  if grep -nE "$pattern" "$f" >/dev/null 2>&1; then
    # Allow obvious placeholders in docs/examples.
    filtered=$(grep -nE "$pattern" "$f" | grep -vE 'YOUR/WEBHOOK/URL|YOUR_[A-Z0-9_]*|CHANGEME|PLACEHOLDER' || true)
    [[ -n "$filtered" ]] || continue
    while IFS= read -r line; do
      hits+=("$line")
    done < <(printf '%s\n' "$filtered" | sed "s#^#$f:#")
  fi
done <<< "$staged_files"

if (( ${#hits[@]} > 0 )); then
  echo ""
  echo "[pre-commit] Potential secret detected. Commit blocked."
  printf '%s\n' "${hits[@]}"
  echo ""
  echo "If this is a false positive, remove/redact before commit."
  exit 1
fi

exit 0
